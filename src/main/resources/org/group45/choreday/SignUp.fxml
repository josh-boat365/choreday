                        <Label alignment="CENTER" contentDisplay="CENTER" text="(c) All rights reserved - 2026 - Java Project - Group 45" textAlignment="CENTER" textFill="WHITE" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
                            <font>
                                <Font name="Calibri" size="12.0" />
                            </font>
                        </Label>
                    </children>
                </AnchorPane>
                <AnchorPane style="-fx-background-color: #ffffff;" GridPane.columnIndex="1">
                    <children>
                        <VBox alignment="CENTER_LEFT" layoutX="60.0" layoutY="80.0" spacing="8.0" AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0" AnchorPane.topAnchor="80.0">
